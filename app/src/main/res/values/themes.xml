<?xml version="1.0" encoding="utf-8"?>
<!-- EST SB Smart Attendance - App Theme -->
<resources>
    <!-- Base application theme -->
    <style name="Theme.SmartAttendance" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primaryBlue</item>
        <item name="colorPrimaryDark">@color/primaryDark</item>
        <item name="colorAccent">@color/accentBlue</item>
        <item name="android:statusBarColor">@color/statusBarColor</item>
        <item name="android:navigationBarColor">@color/primaryDark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Splash screen theme (fullscreen, no status bar) -->
    <style name="Theme.SmartAttendance.Splash" parent="Theme.SmartAttendance">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/primaryDark</item>
    </style>

    <!-- Premium Card Style -->
    <style name="PremiumCard">
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">@dimen/card_padding</item>
    </style>

    <!-- Glass Card Style (semi-transparent) -->
    <style name="GlassCard">
        <item name="cardCornerRadius">@dimen/card_corner_radius_large</item>
        <item name="cardElevation">8dp</item>
        <item name="cardBackgroundColor">@color/cardOverlay</item>
    </style>

    <!-- Premium Button -->
    <style name="PremiumButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">@dimen/text_button</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.03</item>
        <item name="cornerRadius">@dimen/button_corner_radius</item>
        <item name="android:paddingTop">@dimen/button_padding_vertical</item>
        <item name="android:paddingBottom">@dimen/button_padding_vertical</item>
    </style>

    <!-- Input Field Style -->
    <style name="PremiumInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
        <item name="boxStrokeColor">@color/inputBorderFocused</item>
        <item name="hintTextColor">@color/accentBlue</item>
    </style>

    <!-- Section Title -->
    <style name="SectionTitle">
        <item name="android:textSize">@dimen/text_h3</item>
        <item name="android:textColor">@color/textPrimary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Status Badge -->
    <style name="StatusBadge">
        <item name="android:textSize">@dimen/text_caption</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
        <item name="android:paddingTop">4dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>
</resources>
