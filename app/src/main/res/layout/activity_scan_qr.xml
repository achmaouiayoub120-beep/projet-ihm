<?xml version="1.0" encoding="utf-8"?>
<!-- EST SB Smart Attendance - Scan QR Code Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:gravity="center"
    android:orientation="vertical">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_xl">

        <TextView
            android:id="@+id/btnScanBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/input_background"
            android:gravity="center"
            android:text="‹"
            android:textColor="@color/white"
            android:textSize="28sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/scan_qr_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_h4"
            android:textStyle="bold" />

        <android.widget.Space
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- SCANNING SECTION (shown while waiting/scanning) -->
    <LinearLayout
        android:id="@+id/scanningSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxxl">

        <!-- Scanning icon placeholder -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/input_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="📷"
                android:textSize="60sp" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:gravity="center"
            android:text="@string/scan_instruction"
            android:textColor="#CCFFFFFF"
            android:textSize="@dimen/text_body" />
    </LinearLayout>

    <!-- SUCCESS SECTION (shown after successful scan) -->
    <LinearLayout
        android:id="@+id/successSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="@dimen/spacing_xxxl"
        android:visibility="gone">

        <!-- Success circle -->
        <FrameLayout
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/card_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="✓"
                android:textColor="@color/emerald"
                android:textSize="80sp" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtScanStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="@string/scan_success_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_h2"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtScannedModule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_lg"
            android:textColor="@color/accentBlue"
            android:textSize="@dimen/text_h4" />
    </LinearLayout>
</LinearLayout>
