<?xml version="1.0" encoding="utf-8"?>
<!-- EST SB Smart Attendance - Premium Login Screen Layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_xxl">

        <!-- ============================================ -->
        <!-- HEADER SECTION: Logo + App Title             -->
        <!-- ============================================ -->
        <LinearLayout
            android:id="@+id/headerSection"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:alpha="0"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Logo circle -->
            <FrameLayout
                android:layout_width="@dimen/logo_size"
                android:layout_height="@dimen/logo_size"
                android:background="@drawable/qr_container_bg"
                android:elevation="8dp"
                android:padding="15dp">

                <ImageView
                    android:layout_width="@dimen/logo_image_size"
                    android:layout_height="@dimen/logo_image_size"
                    android:layout_gravity="center"
                    android:contentDescription="@string/institution_short"
                    android:src="@drawable/logo_est_sb" />
            </FrameLayout>

            <!-- EST SB Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.1"
                android:text="@string/institution_short"
                android:textColor="@color/white"
                android:textSize="28sp" />

            <!-- Smart Attendance subtitle -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.03"
                android:text="@string/smart_attendance"
                android:textColor="@color/glowBlue"
                android:textSize="@dimen/text_body_small" />
        </LinearLayout>

        <!-- ============================================ -->
        <!-- LOGIN CARD (Glassmorphism style)             -->
        <!-- ============================================ -->
        <LinearLayout
            android:id="@+id/loginCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_xl"
            android:layout_marginTop="@dimen/spacing_xxxl"
            android:layout_marginEnd="@dimen/spacing_xl"
            android:alpha="0"
            android:background="@drawable/glass_card_bg"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Welcome Title -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="@string/welcome_title"
                android:textColor="@color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <!-- Welcome Subtitle -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="28dp"
                android:gravity="center"
                android:text="@string/welcome_subtitle"
                android:textColor="#99FFFFFF"
                android:textSize="15sp" />

            <!-- Email Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:contentDescription="Email"
                    android:src="@android:drawable/sym_action_email"
                    android:tint="@color/textTertiary" />

                <EditText
                    android:id="@+id/editEmail"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/email_hint"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/white"
                    android:textColorHint="#66FFFFFF"
                    android:textSize="@dimen/text_body" />
            </LinearLayout>

            <!-- Password Input -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginBottom="@dimen/spacing_lg"
                android:background="@drawable/input_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="@dimen/spacing_lg"
                android:paddingEnd="@dimen/spacing_lg">

                <ImageView
                    android:layout_width="@dimen/icon_sm"
                    android:layout_height="@dimen/icon_sm"
                    android:contentDescription="Password"
                    android:src="@android:drawable/ic_lock_idle_lock"
                    android:tint="@color/textTertiary" />

                <EditText
                    android:id="@+id/editPassword"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/spacing_md"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/password_hint"
                    android:inputType="textPassword"
                    android:textColor="@color/white"
                    android:textColorHint="#66FFFFFF"
                    android:textSize="@dimen/text_body" />

                <ImageView
                    android:id="@+id/btnTogglePassword"
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:contentDescription="Toggle password"
                    android:padding="2dp"
                    android:src="@android:drawable/ic_secure"
                    android:tint="@color/textTertiary" />
            </LinearLayout>

            <!-- Remember Me + Forgot Password row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_xxl"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkRemember"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:buttonTint="@color/accentBlue"
                    android:text="@string/remember_me"
                    android:textColor="#CCFFFFFF"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/forgot_password"
                    android:textColor="@color/glowBlue"
                    android:textSize="@dimen/text_body_small"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Login Button (Premium gradient) -->
            <TextView
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:layout_marginBottom="@dimen/spacing_xxl"
                android:background="@drawable/button_gradient"
                android:elevation="4dp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:text="@string/login_button"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />

            <!-- =============================== -->
            <!-- DEMO ACCOUNTS SECTION           -->
            <!-- =============================== -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#1AFFFFFF" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xl"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:letterSpacing="0.03"
                android:text="@string/demo_accounts_title"
                android:textColor="#80FFFFFF"
                android:textSize="@dimen/text_caption" />

            <!-- Demo account chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Student demo -->
                <LinearLayout
                    android:id="@+id/demoStudent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="@dimen/spacing_md"
                    android:paddingStart="4dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/rounded_chip_bg"
                        android:backgroundTint="@color/accentBlue" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/demo_student"
                        android:textColor="#99FFFFFF"
                        android:textSize="@dimen/text_overline" />
                </LinearLayout>

                <!-- Professor demo -->
                <LinearLayout
                    android:id="@+id/demoProfessor"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingEnd="@dimen/spacing_md"
                    android:paddingStart="4dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/rounded_chip_bg"
                        android:backgroundTint="@color/emerald" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/demo_professor"
                        android:textColor="#99FFFFFF"
                        android:textSize="@dimen/text_overline" />
                </LinearLayout>

                <!-- Admin demo -->
                <LinearLayout
                    android:id="@+id/demoAdmin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp">

                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/rounded_chip_bg"
                        android:backgroundTint="@color/sunset" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/demo_admin"
                        android:textColor="#99FFFFFF"
                        android:textSize="@dimen/text_overline" />
                </LinearLayout>
            </LinearLayout>

            <!-- Demo password -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:gravity="center"
                android:text="@string/demo_password"
                android:textColor="#66FFFFFF"
                android:textSize="@dimen/text_overline" />

        </LinearLayout>

        <!-- ============================================ -->
        <!-- FOOTER                                       -->
        <!-- ============================================ -->
        <TextView
            android:id="@+id/footerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:alpha="0"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02"
            android:text="@string/institution_name"
            android:textColor="#80FFFFFF"
            android:textSize="@dimen/text_caption" />

    </LinearLayout>
</ScrollView>
