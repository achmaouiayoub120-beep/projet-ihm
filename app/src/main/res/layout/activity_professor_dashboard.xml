<?xml version="1.0" encoding="utf-8"?>
<!-- EST SB Smart Attendance - Professor Dashboard Layout -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- ============================================ -->
    <!-- HEADER with gradient background              -->
    <!-- ============================================ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/header_gradient"
        android:orientation="vertical"
        android:paddingStart="@dimen/spacing_xl"
        android:paddingTop="@dimen/spacing_xl"
        android:paddingEnd="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_xl">

        <!-- Top bar: Logo + Title + Logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Logo -->
            <FrameLayout
                android:layout_width="@dimen/logo_size_small"
                android:layout_height="@dimen/logo_size_small"
                android:background="@drawable/input_background"
                android:padding="6dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/institution_short"
                    android:src="@mipmap/ic_launcher" />
            </FrameLayout>

            <!-- Title -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_md"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:text="@string/institution_short"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_h3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/smart_attendance"
                    android:textColor="#CCFFFFFF"
                    android:textSize="@dimen/text_caption" />
            </LinearLayout>

            <!-- Logout button -->
            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/input_background"
                android:gravity="center"
                android:text="⇥"
                android:textColor="@color/white"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- User info card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xl"
            android:background="@drawable/input_background"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/spacing_lg">

            <!-- Avatar circle -->
            <TextView
                android:id="@+id/txtAvatar"
                android:layout_width="@dimen/avatar_size"
                android:layout_height="@dimen/avatar_size"
                android:background="@drawable/card_background"
                android:gravity="center"
                android:text="MP"
                android:textColor="@color/primaryBlue"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <!-- User details -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_lg"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/welcome_prefix"
                    android:textColor="#CCFFFFFF"
                    android:textSize="@dimen/text_body_small" />

                <TextView
                    android:id="@+id/txtUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_h4"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtUserEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#CCFFFFFF"
                    android:textSize="@dimen/text_caption" />

                <!-- Role badge -->
                <TextView
                    android:id="@+id/txtRoleBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/rounded_chip_bg"
                    android:backgroundTint="@color/emerald"
                    android:paddingStart="10dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="4dp"
                    android:text="@string/role_professor"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_overline"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ============================================ -->
    <!-- CONTENT with ScrollView                      -->
    <!-- ============================================ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_xl">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- STATISTICS SECTION -->
            <LinearLayout
                android:id="@+id/statsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:text="Statistiques"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/text_h4"
                    android:textStyle="bold" />

                <!-- Stats cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Sessions stat card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/spacing_sm"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_lg">

                            <TextView
                                android:id="@+id/txtStatSessions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/primaryBlue"
                                android:textSize="@dimen/text_h2"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/total_sessions"
                                android:textColor="@color/textTertiary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Attendance stat card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_xs"
                        android:layout_marginEnd="@dimen/spacing_xs"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_lg">

                            <TextView
                                android:id="@+id/txtStatAttendance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="@color/emerald"
                                android:textSize="@dimen/text_h2"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/total_attendance"
                                android:textColor="@color/textTertiary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Rate stat card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_lg">

                            <TextView
                                android:id="@+id/txtStatRate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0%"
                                android:textColor="@color/amber"
                                android:textSize="@dimen/text_h2"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="@string/attendance_rate"
                                android:textColor="@color/textTertiary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <!-- QUICK ACTIONS SECTION -->
            <LinearLayout
                android:id="@+id/actionsSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xxl"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:text="@string/quick_actions"
                    android:textColor="@color/textPrimary"
                    android:textSize="@dimen/text_h4"
                    android:textStyle="bold" />

                <!-- Generate QR Action Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnGenerateQR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_xl">

                        <!-- Icon container -->
                        <FrameLayout
                            android:layout_width="@dimen/icon_xl"
                            android:layout_height="@dimen/icon_xl"
                            android:background="@drawable/rounded_chip_bg"
                            android:backgroundTint="#1A1E5FA8">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📱"
                                android:textSize="22sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/generate_qr_session"
                                android:textColor="@color/textPrimary"
                                android:textSize="@dimen/text_body"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Créer une session de présence"
                                android:textColor="@color/textTertiary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/textTertiary"
                            android:textSize="24sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- View History Action Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/btnViewHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_md"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_xl">

                        <FrameLayout
                            android:layout_width="@dimen/icon_xl"
                            android:layout_height="@dimen/icon_xl"
                            android:background="@drawable/rounded_chip_bg"
                            android:backgroundTint="#1A4CAF50">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📊"
                                android:textSize="22sp" />
                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/spacing_lg"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/view_history"
                                android:textColor="@color/textPrimary"
                                android:textSize="@dimen/text_body"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Consulter les enregistrements"
                                android:textColor="@color/textTertiary"
                                android:textSize="@dimen/text_caption" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="@color/textTertiary"
                            android:textSize="24sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
