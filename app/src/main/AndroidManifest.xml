<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Camera permission for QR scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.SmartAttendance">

        <!-- Splash Screen (Launcher) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.SmartAttendance.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login -->
        <activity
            android:name=".activities.LoginActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Professor Dashboard -->
        <activity android:name=".activities.ProfessorDashboardActivity" />

        <!-- Student Dashboard -->
        <activity android:name=".activities.StudentDashboardActivity" />

        <!-- Generate QR Code -->
        <activity android:name=".activities.GenerateQRActivity" />

        <!-- Scan QR Code -->
        <activity android:name=".activities.ScanQRActivity" />

        <!-- Attendance History -->
        <activity android:name=".activities.HistoryActivity" />

        <!-- Session Details -->
        <activity android:name=".activities.SessionDetailsActivity" />

    </application>
</manifest>
